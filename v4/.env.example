# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-key

# WeChat Official Account
WECHAT_APPID=wx_your_appid
WECHAT_APPSECRET=your_appsecret

# Notification
NOTIFY_WEBHOOK_URL=https://your-webhook.example.com/notify

# PostgreSQL (默认值，生产请修改)
PG_USER=n8n
PG_PASSWORD=n8n_secret
PG_DB=n8n_wechat

# Embedding (V2 Qdrant 启用后配置)
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_API_URL=http://localhost:8000/embed
