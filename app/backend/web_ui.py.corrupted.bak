  <button class="btn btn-outline btn-sm" onclick="skipOnboarding()" style="margin-top:8px">璺宠繃锛屾垜鐔熸倝鎿嶄綔</button>
</div>
</div>

<!-- SIDEBAR -->
<aside class="sidebar">
