WEB_PAGE_HTML = r"""
<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>鍏紬鍙稟I杩愯惀绯荤粺 v2.1.3</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:"Microsoft YaHei","寰蒋闆呴粦",sans-serif;background:#f0f2f5;display:flex;min-height:100vh}
.sidebar{width:220px;background:#1a1a2e;color:#fff;padding:24px 0;flex-shrink:0;display:flex;flex-direction:column}
.sidebar .logo{font-size:18px;font-weight:bold;padding:0 20px 30px;color:#7c83ff}
.sidebar nav{flex:1}
.sidebar nav a{display:flex;align-items:center;gap:10px;padding:12px 20px;color:#a0a3b1;text-decoration:none;font-size:14px;transition:.2s}
.sidebar nav a:hover,.sidebar nav a.active{background:#252540;color:#fff}
.sidebar .version{padding:16px 20px;font-size:11px;color:#555;border-top:1px solid #252540}
.main{flex:1;padding:24px 32px;overflow-y:auto;max-height:100vh}
.header{display:flex;justify-content:space-between;align-items:center;margin-bottom:24px}
.header h2{font-size:22px;color:#1a1a2e}
.badge{background:#7c83ff20;color:#7c83ff;padding:4px 12px;border-radius:20px;font-size:12px}
.card{background:#fff;border-radius:12px;padding:24px;margin-bottom:20px;box-shadow:0 1px 4px rgba(0,0,0,.06)}
.card h3{font-size:16px;color:#333;margin-bottom:16px}
.form-row{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:16px;align-items:flex-end}
.form-group{display:flex;flex-direction:column;flex:1;min-width:180px}
.form-group label{font-size:13px;color:#666;margin-bottom:6px;font-weight:bold}
.form-group input,.form-group select{padding:10px 14px;font-size:14px;border:1px solid #ddd;border-radius:8px;font-family:inherit;background:#fafafa}
.form-group input:focus,.form-group select:focus{outline:none;border-color:#7c83ff;background:#fff}
.btn{padding:10px 24px;border-radius:8px;font-size:14px;font-weight:bold;cursor:pointer;border:none;transition:.2s;font-family:inherit}
.btn-primary{background:linear-gradient(135deg,#667eea,#764ba2);color:#fff}
.btn-primary:hover{opacity:.9}
.btn-primary:disabled{opacity:.5;cursor:not-allowed}
.btn-outline{border:1px solid #ddd;background:#fff;color:#666}
.btn-outline:hover{background:#f5f5f5}
.btn-sm{padding:6px 16px;font-size:13px}
.btn-xs{padding:4px 12px;font-size:12px}
.btn-danger{border:1px solid #f44336;background:#fff;color:#f44336}
.btn-danger:hover{background:#fee}
.progress-wrap{margin-top:24px;display:none}
.progress-bar{width:100%;height:8px;background:#eee;border-radius:4px;overflow:hidden;margin-bottom:8px}
.progress-fill{height:100%;background:linear-gradient(90deg,#667eea,#764ba2);border-radius:4px;transition:width .5s;width:0%}
.progress-text{font-size:13px;color:#666;display:flex;justify-content:space-between}
.progress-label{display:flex;align-items:center;gap:6px}
.spin{display:inline-block;width:14px;height:14px;border:2px solid #ccc;border-top-color:#7c83ff;border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.result{margin-top:20px;padding:20px;background:#f8f9fa;border-radius:10px;border-left:4px solid #7c83ff;display:none}
.result h4{font-size:17px;color:#333;margin-bottom:8px}
.result .sum{color:#666;line-height:1.8;margin-bottom:12px;font-size:14px}
.tags{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px}
.tag{padding:4px 12px;border-radius:20px;font-size:12px}
.tag-score{background:#e8f5e9;color:#2e7d32}
.tag-safe{background:#e3f2fd;color:#1565c0}
.tag-keyword{background:#fff3e0;color:#e65100}
.error-alert{margin-top:16px;padding:14px;background:#fff3f3;border-radius:8px;color:#d93025;font-size:14px;display:none}
.task-list{width:100%;border-collapse:collapse}
.task-list th{text-align:left;padding:10px 14px;font-size:13px;color:#999;border-bottom:1px solid #eee}
.task-list td{padding:12px 14px;font-size:14px;border-bottom:1px solid #f5f5f5}
.task-list tr:hover td{background:#fafafa}
.task-list .status-dot{display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:6px}
.status-done{background:#4caf50}.status-fail{background:#f44336}.status-running{background:#ff9800}.status-wait{background:#bdbdbd}
.empty{text-align:center;color:#999;padding:30px;font-size:14px}
.mode-switch{display:flex;gap:0;margin-bottom:20px;border-radius:8px;overflow:hidden;border:1px solid #ddd;width:fit-content}
.mode-btn{padding:8px 20px;font-size:13px;border:none;background:#fff;color:#666;cursor:pointer;font-family:inherit;transition:.2s}
.mode-btn.active{background:#7c83ff;color:#fff}
#linkMode{display:none}
.status-badge{display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:20px;font-size:12px;font-weight:bold}
.status-ok{background:#e8f5e9;color:#2e7d32}
.status-err{background:#fff3f3;color:#d93025}
.status-pending{background:#fff8e1;color:#f57c00}
.article-preview{max-height:500px;overflow-y:auto;border:1px solid #eee;border-radius:8px;padding:20px;background:#fafafa;line-height:1.8;font-size:14px}
.article-preview h2{font-size:18px;margin:16px 0 8px}
.article-preview p{margin:8px 0;color:#444}
.article-preview img{max-width:100%;border-radius:6px;margin:12px 0}
.article-preview blockquote{border-left:3px solid #7c83ff;padding:8px 16px;margin:12px 0;background:#f0f4ff;color:#555}
.onboarding{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.6);display:flex;align-items:center;justify-content:center;z-index:1000}
.onboarding-card{background:#fff;border-radius:16px;padding:40px;max-width:480px;width:90%;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,.3)}
.onboarding-card h2{font-size:22px;color:#1a1a2e;margin-bottom:8px}
.onboarding-card .step-num{width:40px;height:40px;border-radius:50%;background:#7c83ff20;color:#7c83ff;display:inline-flex;align-items:center;justify-content:center;font-size:18px;font-weight:bold;margin-bottom:16px}
.onboarding-card p{color:#666;margin:8px 0 20px;line-height:1.6}
.steps-dots{display:flex;gap:6px;justify-content:center;margin:16px 0}
.steps-dots span{width:8px;height:8px;border-radius:50%;background:#ddd}
.steps-dots span.active{background:#7c83ff}
.toast{position:fixed;top:20px;right:20px;padding:12px 24px;border-radius:8px;font-size:14px;z-index:2000;animation:slideIn .3s ease;box-shadow:0 4px 12px rgba(0,0,0,.15)}
.toast-ok{background:#e8f5e9;color:#2e7d32}
.toast-err{background:#fff3f3;color:#d93025}
@keyframes slideIn{from{transform:translateX(100%);opacity:0}to{transform:translateX(0);opacity:1}}
.img-grid{display:flex;gap:12px;flex-wrap:wrap;margin:12px 0}
.img-card{width:120px;border-radius:8px;overflow:hidden;background:#f5f5f5;text-align:center;font-size:11px}
.img-card img{width:100%;height:80px;object-fit:cover}
.img-card span{display:block;padding:4px 6px;color:#666}
.config-status{display:flex;align-items:center;gap:12px;padding:10px 0}
.mode-indicator{display:inline-flex;align-items:center;gap:6px;padding:4px 14px;border-radius:20px;font-size:12px;font-weight:bold;margin-left:12px}
.mode-full{background:#e8f5e9;color:#2e7d32}
.mode-text{background:#fff8e1;color:#f57c00}
</style>
</head>
<body>

<!-- ONBOARDING -->
<div id="onboarding" class="onboarding" style="display:flex">
